#include <stdio.h>
#define MAX 5

int stack[MAX], top = -1;

int main()
{
    int ch, x, i;

    while (1)
    {
        printf("\n1.Push 2.Pop 3.Display 4.Exit\n");
        scanf("%d", &ch);

        switch (ch)
        {
            case 1:
                if (top == MAX - 1)
                    printf("Stack Overflow\n");
                else
                {
                    scanf("%d", &x);
                    stack[++top] = x;
                }
                break;

            case 2:
                if (top == -1)
                    printf("Stack Underflow\n");
                else
                    printf("Deleted: %d\n", stack[top--]);
                break;

            case 3:
                if (top == -1)
                    printf("Stack is Empty\n");
                else
                {
                    for (i = top; i >= 0; i--)
                        printf("%d ", stack[i]);
                    printf("\n");
                }
                break;

            case 4:
                return 0;

            default:
                printf("Invalid Choice\n");
        }
    }
}
